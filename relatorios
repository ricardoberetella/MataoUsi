<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Relatórios - MataoUsi</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f1f5f9;
      display: flex;
      height: 100vh;
      overflow: hidden;
    }

    /* MENU */
    .sidebar {
      width: 240px;
      background: #0f172a;
      color: white;
      padding: 20px;
      display: flex;
      flex-direction: column;
    }

    .sidebar h2 {
      color: #38bdf8;
      text-align: center;
      margin-bottom: 20px;
    }

    .menu-item {
      padding: 12px;
      margin: 6px 0;
      background-color: rgba(255,255,255,0.1);
      border-radius: 5px;
      cursor: pointer;
      text-align: center;
    }

    .menu-item a {
      text-decoration: none;
      color: white;
      display: block;
      font-size: 15px;
    }

    .menu-item.active {
      background-color: rgba(56,189,248,0.4);
    }

    /* CONTEÚDO */
    .content {
      flex: 1;
      padding: 20px;
      overflow-y: auto;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: white;
      padding: 15px;
      border-radius: 8px;
      margin-bottom: 20px;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .btn-logout {
      background: #ef4444;
      color: white;
      border: none;
      padding: 10px 14px;
      border-radius: 5px;
      cursor: pointer;
      font-weight: bold;
    }

    .card {
      background: white;
      padding: 20px;
      margin-bottom: 20px;
      border-radius: 10px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 10px;
    }

    th, td {
      border: 1px solid #e2e8f0;
      padding: 8px;
      font-size: 14px;
    }

    th {
      background: #e5e7eb;
    }

    input, select {
      padding: 8px;
      width: 100%;
      margin-top: 6px;
      border: 1px solid #cbd5e1;
      border-radius: 5px;
    }

    .filter-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 10px;
    }

    .btn-primary {
      padding: 10px;
      background: #38bdf8;
      border: none;
      color: white;
      font-weight: bold;
      border-radius: 5px;
      margin-top: 10px;
    }

    .btn-primary:hover {
      background: #0ea5e9;
    }
  </style>
</head>

<body>

  <!-- MENU -->
  <div class="sidebar">
    <h2>MataoUsi</h2>

    <div class="menu-item"><a href="dashboard.html">🏠 Início</a></div>
    <div class="menu-item"><a href="empresas.html">🏭 Empresas</a></div>
    <div class="menu-item"><a href="produtos.html">📦 Produtos</a></div>
    <div class="menu-item"><a href="fornecedores.html">🚚 Fornecedores</a></div>
    <div class="menu-item"><a href="estoque.html">📊 Estoque</a></div>
    <div class="menu-item"><a href="movimentacoes.html">📝 Movimentações</a></div>
    <div class="menu-item active"><a href="relatorios.html">📈 Relatórios</a></div>

    <div class="menu-item"><a target="_blank" href="https://github.com/ricardoberetella/MataoUsi">🔗 GitHub</a></div>
  </div>

  <!-- CONTEÚDO -->
  <div class="content">

    <div class="header">
      <h1>Relatórios</h1>
      <button class="btn-logout" id="btnLogout">Sair</button>
    </div>

    <!----------------------------- RELATÓRIO DE ESTOQUE ----------------------------->
    <div class="card">
      <h2>📦 Estoque Atual</h2>
      <table id="tabelaEstoque">
        <thead>
          <tr>
            <th>ID</th>
            <th>Produto</th>
            <th>Quantidade</th>
            <th>Local</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>

    <!----------------------- RELATÓRIO DE MOVIMENTAÇÕES ---------------------------->
    <div class="card">
      <h2>📝 Filtrar Movimentações</h2>

      <div class="filter-grid">

        <div>
          <label>Data Inicial</label>
          <input type="date" id="dtInicio">
        </div>

        <div>
          <label>Data Final</label>
          <input type="date" id="dtFim">
        </div>

        <div>
          <label>Produto</label>
          <select id="filtroProduto"></select>
        </div>

        <div>
          <label>Tipo</label>
          <select id="filtroTipo">
            <option value="">Todos</option>
            <option value="entrada">Entrada</option>
            <option value="saida">Saída</option>
          </select>
        </div>

      </div>

      <button class="btn-primary" id="btnFiltrar">Filtrar</button>

      <table id="tabelaMov">
        <thead>
          <tr>
            <th>ID</th>
            <th>Produto</th>
            <th>Tipo</th>
            <th>Quantidade</th>
            <th>Motivo</th>
            <th>Referência</th>
            <th>Data</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>

    </div>

  </div>

  <!-- SCRIPT SUPABASE -->
  <script type="module">
    import { createClient } from "https://cdn.jsdelivr.net/npm/@supabase/supabase-js/+esm";
    import { SUPABASE_URL, SUPABASE_ANON_KEY } from "./config.js";

    const supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

    document.getElementById("btnLogout").addEventListener("click", async () => {
      await supabase.auth.signOut();
      window.location.href = "index.html";
    });

    // Ao abrir página
    window.addEventListener("DOMContentLoaded", () => {
      carregarEstoque();
      carregarProdutos();
      carregarMovimentacoes();
    });

    /* -------------------- CARREGAR ESTOQUE -------------------- */
    async function carregarEstoque() {
      const tabela = document.querySelector("#tabelaEstoque tbody");

      const { data, error } = await supabase
        .from("estoque")
        .select(`
          *,
          produtos (nome)
        `);

      tabela.innerHTML = "";

      if (error || !data) return;

      data.forEach(e => {
        const tr = document.createElement("tr");
        tr.innerHTML = `
          <td>${e.id}</td>
          <td>${e.produtos?.nome ?? "Produto removido"}</td>
          <td>${e.quantidade}</td>
          <td>${e.local ?? ""}</td>
        `;
        tabela.appendChild(tr);
      });
    }

    /* -------------------- CARREGAR PRODUTOS PARA FILTRO -------------------- */
    async function carregarProdutos() {
      const select = document.getElementById("filtroProduto");

      const { data, error } = await supabase.from("produtos").select("*").order("nome");

      if (error) return;

      select.innerHTML = `<option value="">Todos</option>`;

      data.forEach(p => {
        const opt = document.createElement("option");
        opt.value = p.id;
        opt.textContent = p.nome;
        select.appendChild(opt);
      });
    }

    /* -------------------- CARREGAR MOVIMENTAÇÕES -------------------- */
    async function carregarMovimentacoes(filtros = {}) {
      const tabela = document.querySelector("#tabelaMov tbody");
      tabela.innerHTML = "";

      let query = supabase.from("movimentacoes")
        .select(`
          *,
          produtos (nome)
        `)
        .order("criado_em", { ascending: false });

      if (filtros.dtInicio)
        query = query.gte("criado_em", filtros.dtInicio);

      if (filtros.dtFim)
        query = query.lte("criado_em", filtros.dtFim + " 23:59:59");

      if (filtros.produto_id)
        query = query.eq("produto_id", filtros.produto_id);

      if (filtros.tipo)
        query = query.eq("tipo", filtros.tipo);

      const { data, error } = await query;

      if (error || !data) return;

      data.forEach(m => {
        const tr = document.createElement("tr");
        tr.innerHTML = `
          <td>${m.id}</td>
          <td>${m.produtos?.nome ?? "Desconhecido"}</td>
          <td>${m.tipo.toUpperCase()}</td>
          <td>${m.quantidade}</td>
          <td>${m.motivo ?? ""}</td>
          <td>${m.referencia_id ?? ""}</td>
          <td>${m.criado_em ?? ""}</td>
        `;
        tabela.appendChild(tr);
      });
    }

    /* -------------------- FILTRAR -------------------- */
    document.getElementById("btnFiltrar").addEventListener("click", () => {
      const filtros = {
        dtInicio: document.getElementById("dtInicio").value,
        dtFim: document.getElementById("dtFim").value,
        produto_id: document.getElementById("filtroProduto").value,
        tipo: document.getElementById("filtroTipo").value
      };

      carregarMovimentacoes(filtros);
    });

  </script>

</body>
</html>
